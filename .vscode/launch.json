{
  "configurations": [
    {
      "name": "Python 调试程序: 模块",
      "type": "debugpy",
      "request": "launch",
      "module": "enter-your-module-name"
    },
    {
      "name": "prepare_data",
      "type": "debugpy",
      "request": "launch",
      "module": "prepare_dataset.main_chunk",
      "cwd": "/workspace/code",
      "console": "integratedTerminal",
      "args": [
        "task=detectron2"
      ]
    },
    {
      "name": "calibration",
      "type": "debugpy",
      "request": "launch",
      "module": "camera_calibration.main",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      //   "args": [
      //     "/workspace/code/camera_calibration/input_video"
      //   ]
    },
    {
      "name": "camera_position_mapping",
      "type": "debugpy",
      "request": "launch",
      "module": "triangulation.camera_position_mapping",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "sam3d_body",
      "type": "debugpy",
      "request": "launch",
      "module": "SAM3Dbody.main",
      "cwd": "/workspace/code",
      "python": "/opt/conda/envs/sam_3d_body/bin/python",
      "console": "integratedTerminal",
      "args": [
        "infer.gpu=[0]",
      ]
    },
    {
      "name": "split_cycle",
      "type": "debugpy",
      "request": "launch",
      "module": "split_cycle.main",
      "cwd": "/workspace/code",
      "python": "/opt/conda/envs/sam_3d_body/bin/python",
      "console": "integratedTerminal",
      "args": [
        // "infer.gpu=[0]",
      ]
    },
    {
      "name": "train_stgcn",
      "type": "debugpy",
      "request": "launch",
      "module": "project.train.main",
      "cwd": "/workspace/code",
      "python": "/opt/conda/envs/sam_3d_body/bin/python",
      "console": "integratedTerminal",
      "args": [
        "model.backbone=st_gcn",
        "data.num_workers=0"
      ]
    }
  ]
}